{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter (Android Emulator)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "deviceId": "android"
    },
    {
      "name": "Flutter (iOS Auto)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "preLaunchTask": "Launch iOS Simulator"
    },
    {
      "name": "Flutter (Current Device)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart"
    },
    {
      "name": "Backend API (NodeTS)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/../filmedme-backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
